# Copy to .env.local and fill in to enable observability.
# When any of these are empty the corresponding integration becomes a
# silent no-op (no SDK fetch, no network call, no errors thrown).

# PostHog usage analytics (opt-in via the consent banner).
# Empty key = telemetry disabled. Free EU & US clouds both work.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry crash reporting (opt-in via the consent banner).
# Empty DSN = error tracking disabled.
VITE_SENTRY_DSN=

# Release tag stamped on every Sentry event. Override in CI from the
# commit SHA or package version. Defaults to "dev" when empty.
VITE_APP_VERSION=

# Tip jar — Ko-fi is the canonical donation flow ("sponsorships, not
# surveillance"). The viewer SupportRibbon and the /#whoami page both
# read this. Empty falls back to the public placeholder below; the
# project owner should override to their actual Ko-fi page.
VITE_KOFI_URL=https://ko-fi.com/sboghossian

# Secondary tip route for people who'd rather route through GitHub.
# Shown alongside the Ko-fi link, never alone.
VITE_GITHUB_SPONSORS_URL=https://github.com/sponsors/sboghossian
