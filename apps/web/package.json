{
  "name": "@unspeakable/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && pnpm build:seo && pnpm build:screenshots",
    "build:seo": "node --experimental-strip-types --no-warnings ../../scripts/build-seo-pages.ts",
    "build:screenshots": "node --experimental-strip-types --no-warnings ../../scripts/optimize-screenshots.ts",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit",
    "lint": "echo 'lint: TODO'",
    "test": "vitest run",
    "test:smoke": "playwright test",
    "test:install-browsers": "playwright install --with-deps chromium",
    "bake:asteroids": "node --experimental-strip-types --no-warnings ../../scripts/bake-asteroids.ts",
    "bake:gaia": "node --experimental-strip-types --no-warnings ../../scripts/bake-gaia.ts",
    "bake:missions": "node --experimental-strip-types --no-warnings ../../scripts/bake-missions.ts",
    "bake:eclipses": "node --experimental-strip-types --no-warnings ../../scripts/bake-eclipses.ts",
    "bake:exoplanets:full": "node --experimental-strip-types --no-warnings ../../scripts/bake-exoplanets-full.ts",
    "bake:phl": "node --experimental-strip-types --no-warnings ../../scripts/bake-phl-hwc.ts",
    "bake:multimessenger": "node --experimental-strip-types --no-warnings ../../scripts/bake-multimessenger.ts",
    "bake:galaxy-cone": "node --experimental-strip-types --no-warnings ../../scripts/bake-galaxy-cone.ts",
    "bake:chandra": "node --experimental-strip-types --no-warnings ../../scripts/bake-chandra.ts",
    "bake:variables": "node --experimental-strip-types --no-warnings ../../scripts/bake-variables.ts",
    "bake:planck-polarization": "node --experimental-strip-types --no-warnings ../../scripts/bake-planck-polarization.ts",
    "bake:cosmicflows4": "node --experimental-strip-types --no-warnings ../../scripts/bake-cosmicflows4.ts",
    "bake:jwst-mosaics": "node --experimental-strip-types --no-warnings ../../scripts/bake-jwst-mosaics.ts",
    "bake:sky-cultures-extended": "node --experimental-strip-types --no-warnings ../../scripts/bake-sky-cultures-extended.ts",
    "bake:spice": "node --experimental-strip-types --no-warnings ../../scripts/bake-spice.ts",
    "bake:translate": "node --experimental-strip-types --no-warnings ../../scripts/translate-lessons.ts",
    "bake:translate-ui": "node --experimental-strip-types --no-warnings ../../scripts/translate-ui.ts",
    "verify:imagery": "node --experimental-strip-types --no-warnings ../../scripts/verify-imagery.ts"
  },
  "dependencies": {
    "@hscmap/healpix": "^1.4.12",
    "@sentry/browser": "^10.53.1",
    "astronomy-engine": "^2.1.19",
    "dexie": "^4.4.2",
    "posthog-js": "^1.373.4",
    "qrcode-generator": "^2.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "satellite.js": "^5",
    "three": "^0.171.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/web-worker": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
